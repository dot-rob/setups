# Install to:
# ~/.local/share/xfce4/terminal/colorschemes/nord.theme
# Alternative user path on some systems:
# ~/.config/xfce4/terminal/colorschemes/nord.theme

[Scheme]
Name=Nord
ColorCursor=#ECEFF4
ColorForeground=#D8DEE9
ColorBackground=#2E3440
ColorPalette=#3B4252;#BF616A;#A3BE8C;#EBCB8B;#81A1C1;#B48EAD;#88C0D0;#E5E9F0;#4C566A;#BF616A;#A3BE8C;#EBCB8B;#81A1C1;#B48EAD;#8FBCBB;#ECEFF4
