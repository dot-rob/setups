<?xml version="1.0" encoding="UTF-8"?>
<!--
Install to:
  ~/.local/share/gtksourceview-4/styles/nord.xml

Alternative location on some XFCE/Mousepad builds:
  ~/.local/share/gtksourceview-3.0/styles/nord.xml
-->

<style-scheme id="nord" _name="Nord" version="1.0">
  <author>Alvin Septiano / Nord adaptation by Rob-ChatGPT</author>
  <_description>Nord color scheme for Mousepad / GtkSourceView</_description>
  
	<!-- Nord Color Palette -->
	<color name="background" value="#2E3440"/>
	<color name="current-line" value="#3B4252"/>
	<color name="selection" value="#434C5E"/>
	<color name="foreground" value="#D8DEE9"/>
	<color name="comment" value="#616E88"/>
	<color name="cyan" value="#88C0D0"/>
	<color name="blue" value="#81A1C1"/>
	<color name="green" value="#A3BE8C"/>
	<color name="orange" value="#D08770"/>
	<color name="pink" value="#81A1C1"/>
	<color name="purple" value="#B48EAD"/>
	<color name="red" value="#BF616A"/>
	<color name="yellow" value="#EBCB8B"/>
	<color name="white" value="#ECEFF4"/>
	<color name="bone-white" value="#E5E9F0"/>
	<color name="weird-gray" value="#4C566A"/>

  <!-- Global Settings -->
  <style name="text"                        foreground="foreground" background="background"/>
  <style name="selection"                   foreground="foreground" background="selection"/>
  <style name="cursor"                      foreground="foreground"/>
  <style name="secondary-cursor"            foreground="foreground"/>
  <style name="selection-unfocused"         foreground="foreground" background="current-line"/>
  <style name="current-line"                background="current-line"/>
  <style name="line-numbers"                foreground="comment" background="background"/>
  <style name="background-pattern"          background="background"/>
  <style name="bracket-match"               foreground="green" background="current-line"/>
  <style name="bracket-mismatch"            foreground="red" background="current-line"/>
  <style name="search-match"                foreground="background" background="yellow"/>
  
  <style name="def:keyword"                 foreground="blue" bold="true"/>
  <style name="def:statement"               foreground="blue"/>
  <style name="def:function"                foreground="blue"/>
  <style name="def:decimal"                 foreground="purple"/>
  <style name="def:preprocessor"            foreground="foreground"/>
  <style name="def:type"                    foreground="blue"/>
  
  <style name="def:character"               foreground="green"/>
  
  <style name="def:comment"                 foreground="comment"/>
  <style name="def:number"                  foreground="purple"/>
  <style name="def:string"                  foreground="green"/>
  <style name="def:net-address-in-comment"  foreground="cyan" italic="true" underline="true"/>
  <style name="def:underlined"              italic="true" underline="true"/>
  <style name="def:note"                    foreground="foreground" background="background" bold="true"/>
  <style name="def:error"                   foreground="red" bold="true"/>
  <style name="def:escape"                  foreground="purple"/>
  <style name="def:shebang"                 foreground="blue" bold="true"/>
  <style name="def:doc-comment-element"     italic="true"/>
  <style name="def:identifier"              foreground="green" bold="true"/>
  
  <style name="def:specials"                foreground="background" background="purple"/>
  
  <style name="def:variable"                foreground="orange"/>
  <style name="def:boolean"                 foreground="blue" bold="true"/>
  <style name="def:constant"                foreground="blue"/>
  <style name="def:special-constant"        foreground="blue" bold="true"/>
  
  <style name="diff:added-line"             foreground="foreground"/>
  <style name="diff:removed-line"           foreground="cyan"/>
  <style name="diff:changed-line"           foreground="red"/>
  <style name="diff:diff-file"              foreground="green" bold="true"/>
  <style name="diff:location"               foreground="green"/>
  <style name="diff:special-case"           foreground="foreground" bold="true"/>	
  
  <style name="latex:command"               foreground="orange" bold="true"/>
  <style name="latex:include"               use-style="def:preprocessor"/>
  
  <style name="def:emphasis"                italic="true"/>
  <style name="def:strong-emphasis"         foreground="foreground" bold="true"/>
  <style name="def:inline-code"             foreground="comment"/>
  <style name="def:insertion"               underline="single"/>
  <style name="def:deletion"                strikethrough="true"/>
  <style name="def:link-text"               foreground="cyan"/>
  <style name="def:link-symbol"             foreground="cyan" bold="true"/>
  <style name="def:link-destination"        italic="true" underline="single"/>
  <style name="def:heading"                 foreground="green" bold="true"/>
  <style name="def:thematic-break"          foreground="orange" bold="true"/>
  <style name="def:preformatted-section"    foreground="cyan"/>
  <style name="def:list-marker"             foreground="foreground" bold="true"/>
  
  <style name="def:heading0"                scale="5.0"/>
  <style name="def:heading1"                scale="2.5"/>
  <style name="def:heading2"                scale="2.0"/>
  <style name="def:heading3"                scale="1.7"/>
  <style name="def:heading4"                scale="1.5"/>
  <style name="def:heading5"                scale="1.3"/>
  <style name="def:heading6"                scale="1.2"/>
</style-scheme>
